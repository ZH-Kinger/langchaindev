# 复制此文件为 .env 并填入真实的密钥
# cp .env.example .env

# ============================================================
# 云端大脑 (阿里云 DashScope / Qwen-Max)
# ============================================================
OPENAI_API_KEY=your-dashscope-api-key-here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================================
# 边缘大脑 (ModelScope / Qwen3-4B)
# ============================================================
EDGE_API_KEY=your-modelscope-api-key-here
EDGE_BASE_URL=https://your-modelscope-endpoint.api-inference.modelscope.cn/v1
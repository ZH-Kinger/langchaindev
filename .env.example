# 复制此文件为 .env 并填入真实的密钥
# cp .env.example .env

# ============================================================
# 云端大脑 (阿里云 DashScope / Qwen-Max)
# ============================================================
OPENAI_API_KEY=your-dashscope-api-key-here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================================
# 边缘大脑 (ModelScope / Qwen3-4B)
# ============================================================
EDGE_API_KEY=your-modelscope-api-key-here
EDGE_BASE_URL=https://your-modelscope-endpoint.api-inference.modelscope.cn/v1

# ============================================================
# 阿里云 Prometheus (SLS 托管)
# ============================================================
PROMETHEUS_URL=https://your-workspace.cn-hangzhou.log.aliyuncs.com/prometheus/your-workspace/your-prom-rw-id
ALIYUN_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
# RAM login domain, e.g. 1704065796538912.onaliyun.com
ALIYUN_RAM_LOGIN_DOMAIN=
# Optional token for /api/ram/user. Empty falls back to FEISHU_VERIFICATION_TOKEN.
RAM_QUERY_API_TOKEN=

# ============================================================
# 飞书企业自建应用
# ============================================================
FEISHU_APP_ID=cli_your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_CHAT_ID=oc_your-feishu-chat-id
# 飞书后台 → 事件订阅 → Verification Token
FEISHU_VERIFICATION_TOKEN=your-feishu-verification-token
# 飞书卡片构建器发布的 GPU 申请表单模板 ID（留空则降级为 action buttons 卡片）
FEISHU_GPU_CARD_TEMPLATE_ID=


# ============================================================
# Feishu approval app: RAM sub-account creation
# ============================================================
# Approval definitionCode / approval_code
FEISHU_RAM_APPROVAL_CODE=09F25B71-E1FF-434F-842F-7F2A09F35FAB
# Result notification chat; empty means FEISHU_CHAT_ID
FEISHU_RAM_APPROVAL_RESULT_CHAT_ID=
# true means parse + store in Redis, but do not call Aliyun RAM create APIs
FEISHU_RAM_APPROVAL_DRY_RUN=false
# Allowed RAM groups exposed in the approval form
FEISHU_RAM_APPROVAL_ALLOWED_GROUPS=wuji_Algorithm,wuji_Examination

# Prefer Feishu approval widget IDs here; empty values fall back to field labels
FEISHU_RAM_APPROVAL_FIELD_LOGIN_NAME=
FEISHU_RAM_APPROVAL_FIELD_DISPLAY_NAME=
FEISHU_RAM_APPROVAL_FIELD_EMAIL=
FEISHU_RAM_APPROVAL_FIELD_MOBILE=
FEISHU_RAM_APPROVAL_FIELD_PASSWORD=
FEISHU_RAM_APPROVAL_FIELD_CONFIRM_PASSWORD=
FEISHU_RAM_APPROVAL_FIELD_GROUPS=
FEISHU_RAM_APPROVAL_FIELD_ALIYUN_GROUPS=
FEISHU_RAM_APPROVAL_FIELD_VOLCANO_GROUPS=
FEISHU_RAM_APPROVAL_FIELD_PLATFORMS=
FEISHU_RAM_APPROVAL_FIELD_CONSOLE_ACCESS=
FEISHU_RAM_APPROVAL_FIELD_ACCESS_KEY=
# Defaults are off: missing/empty/no/false all resolve to false
FEISHU_RAM_APPROVAL_FIELD_PASSWORD_RESET=
FEISHU_RAM_APPROVAL_FIELD_MFA_REQUIRED=
FEISHU_RAM_APPROVAL_FIELD_REASON=
FEISHU_RAM_APPROVAL_FIELD_COMMENTS=

# Account delivery:
#   approval_comment = write login/password/AK back to the Feishu approval instance comment
#   email            = send login/password/AK to the approval security email
# Do not use Feishu DM for secrets.
FEISHU_RAM_APPROVAL_DELIVERY=approval_comment
# Comment author for approval comments. Empty falls back to ADMIN_FEISHU_OPEN_ID, then requester open_id.
FEISHU_RAM_APPROVAL_COMMENT_USER_ID=
FEISHU_RAM_APPROVAL_COMMENT_USER_ID_TYPE=open_id
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=bot@example.com
SMTP_PASSWORD=your-smtp-password-or-token
SMTP_FROM=bot@example.com
SMTP_REPLY_TO=ops@example.com
SMTP_USE_SSL=true
SMTP_USE_TLS=true
SMTP_AUTH_REQUIRED=true
SMTP_TIMEOUT_SECONDS=20

# ============================================================
# Redis
# ============================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0

# ============================================================
# Grafana（阿里云 CMS 托管）
# ============================================================
# 访问 Grafana → Configuration → Data Sources → 点击 Prometheus → 地址栏里取 UID
GRAFANA_URL=http://your-grafana-host:3000
GRAFANA_API_KEY=glsa_your-grafana-api-key
GRAFANA_DATASOURCE_UID=your-datasource-uid

# ============================================================
# Jira（GPU 工单系统）
# ============================================================
JIRA_URL=https://jira.your-company.com
JIRA_PAT=your-jira-personal-access-token
JIRA_PROJECT_KEY=GPU
JIRA_ISSUE_TYPE=Task
# 实例运行超时警告时间（小时）
DSW_IDLE_WARN_HOURS=1
# 警告后多久自动停止（分钟）
DSW_IDLE_STOP_MINUTES=30
# 管理员飞书 open_id（用于审批流，留空则 >4GPU/>48h 申请自动批准）
ADMIN_FEISHU_OPEN_ID=
# GPU 定价（元/GPU·小时）
GPU_PRICE_PER_HOUR=35.0
# 每人每月配额上限（GPU·小时），0 表示不限制
GPU_QUOTA_HOURS_PER_MONTH=200.0
# GPU 空转检测：利用率低于此值（%）持续 GPU_IDLE_WARN_MINUTES 分钟告警
GPU_IDLE_THRESHOLD_PCT=5.0
GPU_IDLE_WARN_MINUTES=30

# ============================================================
# 阿里云 PAI DSW（Python SDK，无需 Node.js）
# ============================================================
# 若 PAI DSW 使用独立 AccessKey（与 Prometheus 分开），在此填写；否则留空复用上方的
PAI_DSW_ACCESS_KEY_ID=your-aliyun-access-key-id
PAI_DSW_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
PAI_DSW_REGION_ID=cn-hangzhou
PAI_DSW_WORKSPACE_ID=your-workspace-id
PAI_DSW_RESOURCE_ID=your-resource-id

# ============================================================
# 阿里云 Bot Master 账号（STS AssumeRole）
# ============================================================
# 用 STS 替代用户手动注册 AK/SK，更安全。
# 配置步骤见 docs（或问开发）:
#   1. RAM 控制台新建用户 feishu-bot-master，挂 AliyunSTSAssumeRoleAccess + AliyunRAMReadOnlyAccess
#   2. 为该用户生成 AccessKey
#   3. 新建一个或多个 BotRole-* 角色，信任策略允许 master 用户 AssumeRole
ALIYUN_BOT_MASTER_AK_ID=
ALIYUN_BOT_MASTER_AK_SECRET=
ALIYUN_BOT_ACCOUNT_UID=
ALIYUN_STS_REGION_ID=cn-hangzhou
# 临时凭证有效期（秒），最短 900，最长 3600（角色配置 max_session_duration 可放宽到 43200）
ALIYUN_STS_DURATION_SECONDS=3600
# 默认角色 ARN（用户未命中下面映射时使用）
ALIYUN_BOT_ROLE_DEFAULT=acs:ram::your-uid:role/BotRole-Default
# 用户组 → 角色映射（JSON 数组，按顺序匹配；用户同时在多组时取首个）
# 示例：[{"group":"algo-team","role":"acs:ram::UID:role/BotRole-Algo"},{"group":"platform-team","role":"acs:ram::UID:role/BotRole-Platform"}]
ALIYUN_BOT_ROLE_MAPPING=[]

# ============================================================
# 用户 AK/SK 加密 key（Fernet）
# ============================================================
# 用户通过飞书表单卡片填入个人 AK/SK 后，Bot 用此 key 加密后存入 Redis。
# 一旦设置后绝不可更换，否则已存的 AK 全部失效。
#
# 生成命令（在本地运行，不要把 key 发给任何人）：
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# 缺失时 Bot 会告警并降级为透明传递（明文存）— 生产环境必须配置。
BOT_CREDS_ENCRYPTION_KEY=
# 用户 AK 闲置自动清理：超过此秒数未使用则失效（默认 30 天）
USER_AK_IDLE_TTL_SECONDS=2592000

# ============================================================
# 工作流（standup / plan / weekly）
# ============================================================
# 算法组 Jira 项目 Key（与 GPU 工单项目分开）
# 留空则默认 SWD；如有其他项目填对应 Key（如 ALGO）
JIRA_WORKFLOW_PROJECT=SWD
# GitHub PAT（需要 repo + read:org 权限）
GITHUB_TOKEN=ghp_your-github-personal-access-token
# GitHub 组织名
GITHUB_ORG=your-org-name
# ============================================================
# 火山引擎 TOS（对象存储容量盘点）
# ============================================================
# 依赖：pip install tos（未安装则 TOS 工具/巡检会友好提示而非报错）
# 静态 AK，不走阿里云 STS。建议用只读、仅授权相关桶的子账号密钥。
#
# 【必填】用到 TOS（manage_tos 查询 或 容量巡检含 tos target）时必须填；否则可留空
TOS_ACCESS_KEY=
TOS_SECRET_KEY=
# 【选填】有默认值，换地域才改：
#   上海 tos-cn-shanghai.volces.com / cn-shanghai；北京 tos-cn-beijing.volces.com / cn-beijing
TOS_ENDPOINT=tos-cn-shanghai.volces.com
TOS_REGION=cn-shanghai
VOLCANO_ACCESS_KEY=
VOLCANO_SECRET_KEY=
VOLCANO_REGION=cn-beijing
VOLCANO_IAM_REGION=cn-beijing
VOLCANO_IAM_LOGIN_URL=https://console.volcengine.com/auth/login/
FEISHU_VOLCANO_IAM_ALLOWED_GROUPS=wuji_group,wuji_product_team,wuji-opration

# ============================================================
# 容量巡检（OSS + TOS 目录大小定时盘点 → 飞书主动推送）
# ============================================================
# 【必填-开关】默认 false=不推送；置 true 才随 bot 模式启动后台巡检线程
CAPACITY_MONITOR_ENABLED=false
#
# 依赖（开启后才需要）：
#   · 飞书推送：FEISHU_APP_ID / FEISHU_APP_SECRET / FEISHU_CHAT_ID（见上方飞书段，bot 模式本就在用）
#   · OSS target：巡检无用户上下文，凭证降级到全局 PAI_DSW_ACCESS_KEY_*，
#     该 AK 必须对目标桶有 ListObjects + GetBucketLocation 权限，否则该 OSS target 取数失败被跳过
#   · TOS target：用上方 TOS_ACCESS_KEY / TOS_SECRET_KEY
#
# 【选填】以下均有默认值，按需改：
# 巡检目标 JSON 数组，每项 {vendor: oss|tos, bucket, prefix[, region]}；默认已含示例两个桶
CAPACITY_MONITOR_TARGETS=[{"vendor":"oss","bucket":"wuji-bucket-hangzhou","prefix":"third-party-data/"},{"vendor":"tos","bucket":"wuji-egocentric-data","prefix":"third-party-data/"}]
# 巡检间隔（小时），默认 6
CAPACITY_MONITOR_INTERVAL_HOURS=6
# 合计超过此 TB 数则卡片标红告警；0=不告警（默认）
CAPACITY_ALERT_THRESHOLD_TB=0
# 推送目标群，留空回退 FEISHU_CHAT_ID
CAPACITY_MONITOR_CHAT_ID=
# 增量缓存：已扫过的交付批次目录不再重扫（批次写完即不变），大幅提速；false=每次全量重算
CAPACITY_BATCH_CACHE_ENABLED=true

# ── 巡检结果写入飞书多维表格（Bitable，三表关联）──────────────────────────
# 【开关】true 才写表；需应用开 bitable 权限且机器人是该多维表格协作者
CAPACITY_BITABLE_ENABLED=false
# 多维表格 app_token（wiki 链接需通过 wiki/v2 接口反查 obj_token）与三张表的 table_id
CAPACITY_BITABLE_APP_TOKEN=
CAPACITY_BITABLE_TABLE_SNAPSHOT=
CAPACITY_BITABLE_TABLE_VENDOR=
CAPACITY_BITABLE_TABLE_BATCH=

# 每日集群算力效率（MFU）日报（9 点推到 FEISHU_CHAT_ID 群，按区域汇总）
CLUSTER_MORNING_REPORT_ENABLED=true
# 统计区域白名单（逗号分隔 regionId，如 cn-hangzhou,cn-beijing）；留空=自动发现所有区域
CLUSTER_REGION=
# 按 GPU 卡型映射单卡峰值 TFLOPS / 显存 GiB（GU8T=H20、L20X=H200）
GPU_PEAK_TFLOPS_BY_TYPE={"GU8T": 148, "L20X": 989}
GPU_MEM_GB_BY_TYPE={"GU8T": 96, "L20X": 141}
GPU_PEAK_TFLOPS=148.0
GPU_ACTIVE_THRESHOLD_PCT=1.0
MFU_LOW_THRESHOLD_PCT=30.0

# OSS 权限每日对账推送（带批准按钮）；true 才起该定时线程
OSS_PERM_PUSH_ENABLED=false
OSS_PERM_PUSH_HOUR=9

# ── 跨云数据迁移（一期 TOS→OSS：阿里在线迁移服务 hcs_mgw）──────────────────────
# 方向决定引擎（目的端拉取）：进 OSS 用阿里在线迁移；进 TOS 用火山迁移（二期）。
# 源火山 TOS 用上方 TOS_ACCESS_KEY/SECRET 接入；目的 OSS 用 RAM role（不落 AK）。
# 默认值按 wuji_il 真实迁移任务校准（杭州 OSS 内网 + 上海 TOS 源）。
TRANSFER_ENABLED=false
MGW_ENDPOINT=cn-hangzhou.mgw.aliyuncs.com   # 迁移服务 endpoint，与目的 OSS 同区
MGW_REGION=cn-hangzhou
MGW_USER_ID=                       # 在线迁移服务 userid（主账号 UID）
# 目的 OSS（用 RAM 角色，不落 AK）。角色名形如 oss-import-<ts>-<bucket>
TRANSFER_OSS_ROLE=                 # 例：oss-import-1775122627630-wuji-bucket-hangzhou
TRANSFER_OSS_REGION=cn-hangzhou
TRANSFER_OSS_INTERNAL=true         # true 走内网域名 oss-<region>-internal（同区免流量费）
# 源火山 TOS：迁移专用区域/凭证，与容量巡检 TOS_* 解耦（便于独立轮换）。留空回退 TOS_*。
TRANSFER_TOS_REGION=cn-shanghai    # wuji_il 源在上海（data-tran 桶）
TRANSFER_TOS_ACCESS_KEY=
TRANSFER_TOS_SECRET_KEY=
TRANSFER_MODE_DEFAULT=full         # full 全量 / lastmodified 增量
TRANSFER_OVERWRITE_DEFAULT=no      # no 跳过同名 / always 覆盖
TRANSFER_APPROVAL_TB=1             # 超过此 TB 需管理员审批
TRANSFER_CHAT_ID=                  # 留空回退 FEISHU_CHAT_ID
# 源桶→目的桶映射（JSON）。键 '<scheme>://<bucket>'，值目的桶名。
TRANSFER_BUCKET_MAP={"tos://data-tran":"wuji-bucket-hangzhou","oss://wuji-bucket-hangzhou":"data-tran"}

# 桶间迁移（同云一次性搬运：阿里 OSS→OSS / 火山 TOS→TOS，复用上面迁移引擎）
BUCKET_TRANSFER_ENABLED=false
# 阿里源 OSS 的 RAM 角色名（需含读权限）。留空回退 TRANSFER_OSS_ROLE（该角色需同时有源读+目的写）
BUCKET_TRANSFER_OSS_SRC_ROLE=

# ── CPFS/NAS 数据预热(Import OSS→CPFS) + 沉降(Export CPFS→OSS)：阿里 NAS DataFlow ──
# 只查现有 DataFlow + 提交任务，不创建/删除绑定。凭证默认走全局主账号 AK（同 MGW，需 nas:*）。
# 用户给完整路径便于识别：CPFS 侧如 /cpfs/cwr/third_party_data/label（去掉挂载前缀 /cpfs
# → DataFlow 文件系统路径 /cwr/third_party_data/label）；OSS 侧 oss://wuji-bucket-hangzhou/wuji_il。
# DataFlow 绑定的目录通常更大，任务只针对其下子目录建 Import/Export。
CPFS_DATAFLOW_ENABLED=false
CPFS_REGION=cn-hangzhou            # CPFS 与 OSS 必须同地域
CPFS_FILE_SYSTEM_ID=               # cpfs-*=通用版 / bmcpfs-*=智算版；裸路径用它，cpfs://<fs>/ 可覆盖
# 多地域多文件系统：发现映射表的 fs 清单，逗号分隔 'fs_id@region'（region 缺省取 CPFS_REGION）。
# 对每个 fs 调 DescribeDataFlows 读出 OSS 绑定 → 飞书卡片下拉选择。cri 开头的镜像仓库桶自动屏蔽。
CPFS_FILE_SYSTEM_IDS=              # 例：bmcpfs-xxx@cn-hangzhou,cpfs-yyy@cn-shanghai
CPFS_MAP_TTL_SECONDS=21600         # 映射表缓存 TTL（默认 6h）
CPFS_MOUNT_PREFIX=/cpfs            # 完整路径去掉的本地挂载前缀
CPFS_CONFLICT_POLICY_DEFAULT=SKIP_THE_FILE   # 智算版任务必填：SKIP_THE_FILE/KEEP_LATEST/OVERWRITE_EXISTING
# 显式覆盖 DataFlow 解析（JSON）：键 'oss://<bucket>' 或 CPFS FileSystemPath，值 DataFlowId。
# 留空则 DescribeDataFlows 按 OSS bucket / 最长 FileSystemPath 前缀自动匹配。
CPFS_DATAFLOW_MAP={}
CPFS_APPROVAL_GB=500               # 超过此 GB 需管理员审批
CPFS_CHAT_ID=                      # 留空回退 FEISHU_CHAT_ID

# ── 火山 vePFS↔TOS 数据预热/沉降（火山 vePFS 数据流动 OpenAPI，凭证复用 TOS_ACCESS_KEY/SECRET）──
# 预热=Import(TOS→vePFS)，沉降=Export(vePFS→TOS)。无 CreateDataFlow 绑定，直接建任务+轮询。
# 前置（控制台一次性）：开通 vePFS→TOS 服务访问授权 + ConfigDataFlowBandwidth 带宽>0。
VEPFS_DATAFLOW_ENABLED=false
VEPFS_REGION=cn-beijing            # vePFS 与 TOS 必须同地域
VEPFS_FILE_SYSTEM_ID=              # 默认文件系统；裸路径用它，vepfs://<fs>/ 可覆盖
VEPFS_FILE_SYSTEM_IDS=            # 多 fs（后续下拉发现用），逗号分隔 'fs_id@region'
VEPFS_CONFLICT_POLICY_DEFAULT=Skip   # 同名策略：Skip/KeepLatest/OverWrite
VEPFS_CHAT_ID=                     # 留空回退 FEISHU_CHAT_ID
